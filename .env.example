# ── Supabase (required) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...your-anon-key-here

# ── Supabase Service Role (required for admin auth operations) ──
# Get from: Supabase Dashboard → Project Settings → API → service_role key (secret)
# ⚠️ NEVER expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...your-service-role-key-here

# ── Session Security (required) ──
# Min 32 chars hex. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=change-this-to-a-long-random-secret

# ── Default Admin Bootstrap (development only) ──
# Disabled by default for safety. Enable ONLY in local development.
# ALLOW_DEFAULT_ADMIN_BOOTSTRAP=true
# When enabled and the employees table is empty, it creates:
# Employee ID: admin001
# Password: Snacks911!

# ── AI Models ──
# GEMINI_API_KEY=           # Primary: gemini-2.5-flash-lite
# OPENAI_API_KEY=           # Secondary: gpt-4o-mini (fallback)

# ── Optional: WhatsApp Number ──
# NEXT_PUBLIC_WHATSAPP=525584507458

# ── Conekta Payments (Mexico) ── REQUIRED for card payments
# 1. Create account at https://conekta.io
# 2. Go to Dashboard → Developers → API Keys → copy your private API key
# 3. Go to Dashboard → Developers → Webhooks → create or view your endpoint
# 4. Copy the webhook public key (starts with -----BEGIN PUBLIC KEY-----)
CONEKTA_API_KEY=key_xxx
CONEKTA_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----"
